dist/
build/
.eggs/

# FastAPI / Uvicorn
*.log

# Hourly log files (auto-generated; directory kept via .gitkeep)
backend/logger/logs/**/*.log

# Alembic
alembic/versions/*.pyc

# Environment variables
.env
.env.local
.env.*.local
*.env

# Node / Frontend
node_modules/
.npm
frontend/dist/
frontend/.vite/
frontend/build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
*.pid

# Database
*.sqlite3
*.db

# Uploads / temp files
backend/uploads/
backend/temp/

# Test coverage
.coverage
htmlcov/
.pytest_cache/
